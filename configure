#!/usr/bin/env bash
# configure — detect platform, download ONNX Runtime, check dependencies
#
# Usage:
#   ./configure [OPTIONS]
#
# Options:
#   --cpu-only        Skip GPU/CUDA support (smaller download, works everywhere)
#   --ort-dir DIR     Use existing ORT installation instead of downloading
#   --prefix DIR      Installation prefix [default: ~/.local]
#
# Writes config.mk which is included by the Makefile.

set -euo pipefail

ORT_VERSION="1.20.1"
CPU_ONLY=0
ORT_DIR=""
PREFIX="$HOME/.local"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --cpu-only)    CPU_ONLY=1; shift ;;
        --ort-dir)     ORT_DIR="$2"; shift 2 ;;
        --prefix)      PREFIX="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,/^$/p' "$0" | grep '^#' | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

echo "=== import_pentacam configure ==="
echo ""

# --- Detect platform ---
ARCH=$(uname -m)
OS=$(uname -s)
echo "Platform: $OS $ARCH"

# Normalize OS: MINGW64_NT-*, MSYS_NT-*, CYGWIN_NT-* all mean Windows
IS_WINDOWS=0
case "$OS" in
    MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1; echo "Detected:  Windows (via $OS)" ;;
    Linux)                 echo "Detected:  Linux" ;;
    Darwin)                echo "WARNING: macOS is untested."; echo "         Set --ort-dir manually." ;;
    *)                     echo "WARNING: Unknown OS '$OS'. Set --ort-dir manually." ;;
esac

if [[ "$ARCH" != "x86_64" ]]; then
    echo "WARNING: Only x86_64 builds are pre-configured."
    echo "         For other architectures, set --ort-dir manually."
fi

# --- Check Rust toolchain ---
if ! command -v cargo &>/dev/null; then
    echo "ERROR: cargo not found. Install Rust: https://rustup.rs"
    exit 1
fi
echo "Rust:     $(rustc --version 2>/dev/null || echo 'not found')"

# --- Check CUDA ---
CUDA_AVAILABLE=0
if command -v nvidia-smi &>/dev/null; then
    GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 || true)
    if [[ -n "$GPU_NAME" ]]; then
        CUDA_AVAILABLE=1
        echo "GPU:      $GPU_NAME"
    fi
fi

if [[ "$CPU_ONLY" -eq 1 ]]; then
    echo "CUDA:     disabled (--cpu-only)"
    CUDA_PROVIDER=0
elif [[ "$CUDA_AVAILABLE" -eq 1 ]]; then
    echo "CUDA:     available"
    CUDA_PROVIDER=1
else
    echo "CUDA:     not detected (building CPU-only)"
    CUDA_PROVIDER=0
fi

# --- Check build tools (Windows) ---
if [[ "$IS_WINDOWS" -eq 1 ]]; then
    if command -v cl &>/dev/null; then
        echo "MSVC:     $(cl 2>&1 | head -1)"
    else
        echo "MSVC:     not in PATH (run from Developer Command Prompt or set up vcvars)"
    fi
    if command -v cmake &>/dev/null; then
        echo "CMake:    $(cmake --version | head -1)"
    else
        echo "CMake:    not found (may be needed for MuPDF compilation)"
    fi
fi

# --- Check optional tools ---
if command -v pdftoppm &>/dev/null; then
    echo "Poppler:  $(pdftoppm -v 2>&1 | head -1)"
else
    echo "Poppler:  not found (optional — only needed with --poppler flag)"
fi

# --- ONNX Runtime ---
if [[ -n "$ORT_DIR" ]]; then
    if [[ ! -d "$ORT_DIR/lib" ]]; then
        echo "ERROR: --ort-dir $ORT_DIR does not contain a lib/ directory"
        exit 1
    fi
    echo "ORT:      $ORT_DIR (user-provided)"
else
    if [[ "$IS_WINDOWS" -eq 1 ]]; then
        if [[ "$CUDA_PROVIDER" -eq 1 ]]; then
            ORT_PACKAGE="onnxruntime-win-x64-gpu-${ORT_VERSION}"
        else
            ORT_PACKAGE="onnxruntime-win-x64-${ORT_VERSION}"
        fi
        ORT_URL="https://github.com/microsoft/onnxruntime/releases/download/v${ORT_VERSION}/${ORT_PACKAGE}.zip"
    else
        if [[ "$CUDA_PROVIDER" -eq 1 ]]; then
            ORT_PACKAGE="onnxruntime-linux-x64-gpu-${ORT_VERSION}"
        else
            ORT_PACKAGE="onnxruntime-linux-x64-${ORT_VERSION}"
        fi
        ORT_URL="https://github.com/microsoft/onnxruntime/releases/download/v${ORT_VERSION}/${ORT_PACKAGE}.tgz"
    fi

    ORT_DIR="$(pwd)/ort/${ORT_PACKAGE}"

    if [[ -d "$ORT_DIR/lib" ]]; then
        echo "ORT:      $ORT_DIR (already downloaded)"
    else
        echo ""
        echo "Downloading ONNX Runtime ${ORT_VERSION} ..."
        echo "  URL: $ORT_URL"
        mkdir -p ort
        if [[ "$IS_WINDOWS" -eq 1 ]]; then
            ORT_ZIP="ort/${ORT_PACKAGE}.zip"
            curl -L --progress-bar "$ORT_URL" -o "$ORT_ZIP"
            unzip -q "$ORT_ZIP" -d ort/
            rm -f "$ORT_ZIP"
        else
            curl -L --progress-bar "$ORT_URL" | tar xz -C ort/
        fi
        echo "ORT:      $ORT_DIR"
    fi
fi

# --- OCR Models ---
MODEL_BASE="https://github.com/GreatV/oar-ocr/releases/download/v0.3.0"
MODEL_DIR="$(pwd)/models"
mkdir -p "$MODEL_DIR"

download_model() {
    local url="$1"
    local dest="$2"
    if [[ -f "$dest" ]]; then
        echo "  $(basename "$dest") (already present)"
    else
        echo "  Downloading $(basename "$dest") ..."
        curl -L --progress-bar "$url" -o "$dest"
    fi
}

echo ""
echo "OCR models:"
download_model "$MODEL_BASE/pp-ocrv5_server_det.onnx" "$MODEL_DIR/pp-ocrv5_server_det.onnx"
download_model "$MODEL_BASE/en_pp-ocrv5_mobile_rec.onnx" "$MODEL_DIR/en_pp-ocrv5_mobile_rec.onnx"
download_model "$MODEL_BASE/ppocrv5_en_dict.txt" "$MODEL_DIR/en_ppocrv5_dict.txt"

# --- Check/download libclang (Windows — needed for bindgen/MuPDF) ---
LLVM_VERSION="18.1.8"
LIBCLANG=""
if [[ "$IS_WINDOWS" -eq 1 ]]; then
    LOCAL_LLVM="$(pwd)/llvm/bin"
    for candidate in \
        "$LOCAL_LLVM" \
        "/c/Program Files/LLVM/bin" \
        "/c/Program Files (x86)/LLVM/bin" \
        "$PROGRAMFILES/LLVM/bin"; do
        if [[ -f "$candidate/libclang.dll" ]]; then
            LIBCLANG="$candidate"
            break
        fi
    done

    if [[ -n "$LIBCLANG" ]]; then
        echo "Clang:    $LIBCLANG/libclang.dll"
    else
        echo ""
        echo "libclang.dll not found — downloading from LLVM ${LLVM_VERSION} release ..."
        LLVM_TAR="clang+llvm-${LLVM_VERSION}-x86_64-pc-windows-msvc.tar.xz"
        LLVM_URL="https://github.com/llvm/llvm-project/releases/download/llvmorg-${LLVM_VERSION}/${LLVM_TAR}"
        LLVM_DL="/tmp/${LLVM_TAR}"

        echo "  URL: $LLVM_URL"
        if [[ -f "$LLVM_DL" ]]; then
            echo "  (archive already cached in $LLVM_DL)"
        else
            curl -L --progress-bar "$LLVM_URL" -o "$LLVM_DL"
        fi

        echo "  Extracting libclang.dll (~96 MB) ..."
        mkdir -p "$(pwd)/llvm/bin"
        tar -xJf "$LLVM_DL" \
            -C "$(pwd)/llvm/bin" \
            --strip-components=2 \
            "clang+llvm-${LLVM_VERSION}-x86_64-pc-windows-msvc/bin/libclang.dll"

        if [[ -f "$(pwd)/llvm/bin/libclang.dll" ]]; then
            LIBCLANG="$(pwd)/llvm/bin"
            echo "Clang:    $LIBCLANG/libclang.dll (downloaded)"
        else
            echo "ERROR: Failed to extract libclang.dll from archive."
            echo "       Install LLVM manually: https://github.com/llvm/llvm-project/releases"
        fi
    fi
fi

# --- Check/download WiX Toolset (Windows — needed for MSI installer) ---
WIX_DIR=""
if [[ "$IS_WINDOWS" -eq 1 ]]; then
    LOCAL_WIX="$(pwd)/wix/bin"
    for candidate in \
        "$LOCAL_WIX" \
        "${WIX:-}/bin" \
        "/c/Program Files/WiX Toolset v3.14/bin" \
        "/c/Program Files (x86)/WiX Toolset v3.14/bin"; do
        if [[ -f "$candidate/candle.exe" ]]; then
            WIX_DIR="$candidate"
            break
        fi
    done

    if [[ -n "$WIX_DIR" ]]; then
        echo "WiX:      $WIX_DIR/candle.exe"
    else
        echo ""
        echo "WiX Toolset not found — downloading portable binaries ..."
        WIX_URL="https://github.com/wixtoolset/wix3/releases/download/wix3141rtm/wix314-binaries.zip"
        WIX_ZIP="$(pwd)/wix/wix314-binaries.zip"

        echo "  URL: $WIX_URL"
        mkdir -p "$(pwd)/wix"
        set +e
        curl -L --progress-bar "$WIX_URL" -o "$WIX_ZIP"
        CURL_EXIT=$?
        set -e

        if [[ "$CURL_EXIT" -eq 0 && -f "$WIX_ZIP" ]]; then
            unzip -q "$WIX_ZIP" -d "$(pwd)/wix/bin"
            rm -f "$WIX_ZIP"
            if [[ -f "$(pwd)/wix/bin/candle.exe" ]]; then
                WIX_DIR="$(pwd)/wix/bin"
                echo "WiX:      $WIX_DIR/candle.exe (downloaded)"
            else
                echo "WARNING:  WiX extraction failed. 'make msi' will not work."
            fi
        else
            echo "WARNING:  WiX download failed. 'make msi' will not work."
            echo "          Install WiX Toolset v3 manually or re-run ./configure."
            rm -f "$WIX_ZIP"
        fi
    fi

    # Check cargo-wix
    if command -v cargo-wix &>/dev/null; then
        echo "cargo-wix: $(cargo wix --version 2>/dev/null || echo 'installed')"
    else
        echo ""
        echo "Installing cargo-wix ..."
        set +e
        cargo install cargo-wix 2>&1 | tail -3
        set -e
        if command -v cargo-wix &>/dev/null; then
            echo "cargo-wix: installed"
        else
            echo "WARNING:  cargo-wix installation failed. 'make msi' will not work."
            echo "          Try manually: cargo install cargo-wix"
        fi
    fi
fi

# --- Write config.mk ---
cat > config.mk <<EOF
# Generated by ./configure — do not edit
ORT_DIR := $ORT_DIR
CUDA_PROVIDER := $CUDA_PROVIDER
PREFIX := $PREFIX
EOF

if [[ -n "$LIBCLANG" ]]; then
    WIN_LIBCLANG=$(cygpath -w "$LIBCLANG" 2>/dev/null || echo "$LIBCLANG")
    cat >> config.mk <<EOF
export LIBCLANG_PATH := $WIN_LIBCLANG
EOF
fi

if [[ -n "$WIX_DIR" ]]; then
    WIN_WIX=$(cygpath -w "$WIX_DIR" 2>/dev/null || echo "$WIX_DIR")
    # WIX_BIN is used by the Makefile's msi target
    cat >> config.mk <<EOF
WIX_BIN := $WIN_WIX
EOF
fi

echo ""
echo "Configuration written to config.mk"
echo ""
echo "Next steps:"
echo "  make              Build release binary"
echo "  make dist         Build + assemble distributable folder"
echo "  make install      Build + install to $PREFIX"
echo ""
